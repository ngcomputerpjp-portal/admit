<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body, html {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden; /* Scrollbars ko hide karne ke liye */
    }
    .iframe-container {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
    iframe {
      width: 100%;
      height: 100%;
      border: none;
    }
  </style>
</head>
<body>

  <div class="iframe-container">
    <iframe src="https://script.google.com/macros/s/AKfycbyJBgYf5pDsOZ8hEBa8ZtXJwveBZhgtLEm31Kirng2TSA5sd8J2Hicu68vmYyL8VrFG/exec" 
            allow="camera; microphone; display-capture">
    </iframe>
  </div>

</body>
</html>
